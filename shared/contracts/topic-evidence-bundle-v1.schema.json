{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.medicaidintelligence.com/schemas/topic-evidence-bundle-v1.schema.json",
  "title": "Reviewed topic evidence bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleId",
    "bundleKind",
    "createdAt",
    "producer",
    "taxonomy",
    "classifier",
    "reports",
    "integrity"
  ],
  "properties": {
    "schemaVersion": { "const": "topic-evidence-bundle/1" },
    "bundleId": { "type": "string", "format": "uuid" },
    "bundleKind": { "const": "reviewed-report-snapshot-delta" },
    "createdAt": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceSystem", "codeRevision", "classificationRunId"],
      "properties": {
        "sourceSystem": { "const": "medicaid-report-ai-miner" },
        "codeRevision": { "type": "string", "minLength": 1, "maxLength": 120 },
        "classificationRunId": { "type": "string", "format": "uuid" }
      }
    },
    "taxonomy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "sha256"],
      "properties": {
        "version": { "type": "string", "minLength": 1, "maxLength": 80 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "classifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "promptVersion",
        "outputSchemaVersion"
      ],
      "properties": {
        "provider": { "type": "string", "minLength": 1, "maxLength": 40 },
        "model": { "type": "string", "minLength": 1, "maxLength": 120 },
        "modelRevision": { "type": ["string", "null"], "maxLength": 120 },
        "promptVersion": { "type": "string", "minLength": 1, "maxLength": 80 },
        "outputSchemaVersion": { "const": "topic-proposal/1" }
      }
    },
    "reports": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/report" }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization",
        "payloadSha256",
        "signatureAlgorithm",
        "keyId",
        "detachedSignature"
      ],
      "properties": {
        "canonicalization": { "const": "RFC8785-JCS" },
        "payloadSha256": { "$ref": "#/$defs/sha256" },
        "signatureAlgorithm": { "const": "Ed25519" },
        "keyId": { "type": "string", "minLength": 1, "maxLength": 120 },
        "detachedSignature": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceIdentity",
        "sourceContentSha256",
        "classifierInputSha256",
        "review",
        "replacement",
        "assignments",
        "validation"
      ],
      "properties": {
        "sourceIdentity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reportUid"],
          "properties": {
            "reportUid": { "type": "string", "format": "uuid" }
          }
        },
        "websiteIdentity": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["reportId"],
          "properties": {
            "reportId": { "type": "integer", "minimum": 1 }
          }
        },
        "sourceContentSha256": { "$ref": "#/$defs/sha256" },
        "classifierInputSha256": { "$ref": "#/$defs/sha256" },
        "review": { "$ref": "#/$defs/review" },
        "replacement": { "$ref": "#/$defs/replacement" },
        "assignments": {
          "type": "array",
          "maxItems": 20,
          "items": { "$ref": "#/$defs/assignment" }
        },
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "checks"],
          "properties": {
            "status": { "const": "valid" },
            "checks": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 120 }
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reviewId", "reviewerId", "completedAt"],
      "properties": {
        "state": { "const": "complete" },
        "reviewId": { "type": "string", "format": "uuid" },
        "reviewerId": { "type": "string", "minLength": 1, "maxLength": 120 },
        "completedAt": { "type": "string", "format": "date-time" },
        "origin": { "enum": ["human", "agent"] },
        "auditStatus": {
          "enum": ["not_required", "unaudited", "endorsed", "corrected"]
        },
        "autoFlags": {
          "type": "array",
          "maxItems": 40,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code"],
            "properties": {
              "code": { "type": "string", "minLength": 1, "maxLength": 40 },
              "topicKey": { "type": "string", "minLength": 1, "maxLength": 80 }
            }
          }
        }
      }
    },
    "replacement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "previousAssignmentSetSha256",
        "retireTopicKeys"
      ],
      "properties": {
        "mode": { "const": "replace-all-reviewed-topics" },
        "previousAssignmentSetSha256": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "retireTopicKeys": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assignmentUid",
        "topicKey",
        "operation",
        "rationale",
        "modelConfidence",
        "confidenceCalibrated",
        "evidence"
      ],
      "properties": {
        "assignmentUid": { "type": "string", "format": "uuid" },
        "topicKey": { "type": "string", "minLength": 1, "maxLength": 80 },
        "operation": { "const": "activate" },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "modelConfidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "confidenceCalibrated": { "const": false },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "evidence": {
      "oneOf": [
        { "$ref": "#/$defs/findingEvidence" },
        { "$ref": "#/$defs/recommendationEvidence" },
        { "$ref": "#/$defs/reportMetadataEvidence" }
      ]
    },
    "findingEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "sourceUid",
        "websiteId",
        "textSha256",
        "snapshot",
        "rank"
      ],
      "properties": {
        "sourceType": { "const": "finding" },
        "sourceUid": { "type": "string", "format": "uuid" },
        "websiteId": { "type": ["integer", "null"], "minimum": 1 },
        "textSha256": { "$ref": "#/$defs/sha256" },
        "snapshot": { "type": "string", "minLength": 1, "maxLength": 20000 },
        "rank": { "type": "integer", "minimum": 1 }
      }
    },
    "recommendationEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "sourceUid",
        "websiteId",
        "textSha256",
        "snapshot",
        "rank"
      ],
      "properties": {
        "sourceType": { "const": "recommendation" },
        "sourceUid": { "type": "string", "format": "uuid" },
        "websiteId": { "type": ["integer", "null"], "minimum": 1 },
        "textSha256": { "$ref": "#/$defs/sha256" },
        "snapshot": { "type": "string", "minLength": 1, "maxLength": 20000 },
        "rank": { "type": "integer", "minimum": 1 }
      }
    },
    "reportMetadataEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "fieldName",
        "valueSha256",
        "snapshot",
        "rank"
      ],
      "properties": {
        "sourceType": { "const": "report_metadata" },
        "fieldName": {
          "enum": [
            "report_title",
            "audit_organization",
            "audit_scope",
            "overall_conclusion",
            "potential_objective_summary"
          ]
        },
        "valueSha256": { "$ref": "#/$defs/sha256" },
        "snapshot": { "type": "string", "minLength": 1, "maxLength": 20000 },
        "rank": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
